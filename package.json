{
  "name": "@ihv/react-hook-table",
  "version": "0.6.5",
  "description": "Lightweight hook table for React",
  "author": "Ivo Etti",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ihv-hook-table/react-hook-table.git"
  },
  "homepage": "https://github.com/ihv-hook-table/react-hook-table",
  "publishConfig": {
    "provenance": true
  },
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc -b && vp build",
    "lint": "vp lint .",
    "preview": "vp preview",
    "knip": "knip",
    "release": "vp pack src/hook-table/index.ts && changeset publish",
    "changeset": "changeset"
  },
  "keywords": [
    "react",
    "hook",
    "table",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "peerDependencies": {
    "react": "^18.x || ^19.x",
    "react-dom": "^18.x || ^19.x"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.0",
    "@changesets/cli": "^2.30.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "knip": "^6.4.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.18",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
